{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "//": "项目级 hooks 配置（committed，全队共享）。①.5 Claude Code hook 层——机械·会话内·可绕过；权威靠 PR 门禁。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/path-guard.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-completion.sh" }
        ]
      }
    ]
  }
}
